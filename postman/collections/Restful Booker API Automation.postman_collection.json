        {
          "name": "Partial Update Booking",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set(\"patchBookingRequest\", pm.request.body.raw)"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseBody = pm.response.json()\r",
                  "const requestBody = JSON.parse(pm.environment.get('patchBookingRequest'))\r",
                  "const previousBooking = JSON.parse(pm.environment.get('updateBookingRequest'))\r",
                  "\r",
                  "// ===== HTTP Validations =====\r",
                  "\r",
                  "pm.test('Status code should be 200', function () {\r",
                  "    pm.response.to.have.status(200)\r",
                  "})\r",
                  "\r",
                  "pm.test('Response time should be below 1000 ms', function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000)\r",
                  "})\r",
                  "\r",
                  "pm.test('Content-Type should be application/json', function () {\r",
                  "    pm.expect(pm.response.headers.get('Content-Type'))\r",
                  "        .to.include('application/json')\r",
                  "})\r",
                  "\r",
                  "// ===== Contract Validations =====\r",
                  "\r",
                  "pm.test('Response body should not be empty', function () {\r",
                  "    pm.expect(responseBody).to.not.be.empty\r",
                  "})\r",
                  "\r",
                  "pm.test('Response body should be an object', function () {\r",
                  "    pm.expect(responseBody).to.be.an('object')\r",
                  "})\r",
                  "\r",
                  "pm.test('Booking dates should be an object', function () {\r",
                  "    pm.expect(responseBody.bookingdates).to.be.an('object')\r",
                  "})\r",
                  "\r",
                  "// ===== Business Validations =====\r",
                  "\r",
                  "pm.test('Firstname should be updated', function () {\r",
                  "    pm.expect(responseBody.firstname).to.eql(requestBody.firstname)\r",
                  "})\r",
                  "\r",
                  "pm.test('Lastname should remain unchanged', function () {\r",
                  "    pm.expect(responseBody.lastname)\r",
                  "        .to.eql(previousBooking.lastname)\r",
                  "})\r",
                  "\r",
                  "pm.test('Total price should remain unchanged', function () {\r",
                  "    pm.expect(responseBody.totalprice)\r",
                  "        .to.eql(previousBooking.totalprice)\r",
                  "})\r",
                  "\r",
                  "pm.test('Deposit paid should remain unchanged', function () {\r",
                  "    pm.expect(responseBody.depositpaid)\r",
                  "        .to.eql(previousBooking.depositpaid)\r",
                  "})\r",
                  "\r",
                  "pm.test('Additional needs should remain unchanged', function () {\r",
                  "    pm.expect(responseBody.additionalneeds)\r",
                  "        .to.eql(previousBooking.additionalneeds)\r",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}

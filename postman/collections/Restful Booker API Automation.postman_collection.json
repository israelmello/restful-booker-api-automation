    {
      "name": "Booking",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const bookingResponse = pm.response.json();\r",
                  "const requestBody = JSON.parse(pm.request.body.raw);\r",
                  "\r",
                  "// Status Code\r",
                  "pm.test(\"Should return status code 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "})\r",
                  "\r",
                  "// Response Time\r",
                  "pm.test(\"Response time should be below 1000 ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "})\r",
                  "\r",
                  "// Content-Type\r",
                  "pm.test(\"Response should be JSON\", function () {\r",
                  "    pm.response.to.have.header(\"Content-Type\");\r",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
                  "})\r",
                  "\r",
                  "// bookingid\r",
                  "pm.test(\"Should return bookingid\", function () {\r",
                  "    pm.expect(bookingResponse.bookingid).to.exist;\r",
                  "})\r",
                  "\r",
                  "pm.test(\"bookingid should be a number\", function () {\r",
                  "    pm.expect(bookingResponse.bookingid).to.be.a(\"number\");\r",
                  "})\r",
                  "\r",
                  "// booking\r",
                  "pm.test(\"Booking should be an object\", function () {\r",
                  "    pm.expect(bookingResponse.booking).to.be.an(\"object\");\r",
                  "})\r",
                  "\r",
                  "// firstname\r",
                  "pm.test(\"Firstname should match request\", function () {\r",
                  "    pm.expect(bookingResponse.booking.firstname).to.eql(requestBody.firstname);\r",
                  "})\r",
                  "\r",
                  "// lastname\r",
                  "pm.test(\"Lastname should match request\", function () {\r",
                  "    pm.expect(bookingResponse.booking.lastname).to.eql(requestBody.lastname);\r",
                  "})\r",
                  "\r",
                  "// totalprice\r",
                  "pm.test(\"Total price should match request\", function () {\r",
                  "    pm.expect(bookingResponse.booking.totalprice).to.eql(requestBody.totalprice);\r",
                  "})\r",
                  "\r",
                  "// depositpaid\r",
                  "pm.test(\"Deposit paid should match request\", function () {\r",
                  "    pm.expect(bookingResponse.booking.depositpaid).to.eql(requestBody.depositpaid);\r",
                  "})\r",
                  "\r",
                  "// bookingdates\r",
                  "pm.test(\"Checkin date should match request\", function () {\r",
                  "    pm.expect(bookingResponse.booking.bookingdates.checkin).to.eql(requestBody.bookingdates.checkin);\r",
                  "})\r",
                  "\r",
                  "pm.test(\"Checkout date should match request\", function () {\r",
                  "    pm.expect(bookingResponse.booking.bookingdates.checkout).to.eql(requestBody.bookingdates.checkout);\r",
                  "})\r",
                  "\r",
                  "// additionalneeds\r",
                  "pm.test(\"Additional needs should match request\", function () {\r",
                  "    pm.expect(bookingResponse.booking.additionalneeds).to.eql(requestBody.additionalneeds);\r",
                  "})\r",
                  "\r",
                  "// Save bookingId\r",
                  "pm.environment.set(\"bookingId\", bookingResponse.bookingid);\r",
                  "\r",
                  "// Save request body for future tests\r",
                  "pm.environment.set(\"createBookingRequest\", pm.request.body.raw);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"firstname\": \"Israel\",\r\n    \"lastname\": \"Mello\",\r\n    \"totalprice\": 1500,\r\n    \"depositpaid\": true,\r\n    \"bookingdates\": {\r\n        \"checkin\": \"2026-07-20\",\r\n        \"checkout\": \"2026-07-25\"\r\n    },\r\n    \"additionalneeds\": \"Breakfast\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/booking",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "booking"
              ]
            }
          },
          "response": []
